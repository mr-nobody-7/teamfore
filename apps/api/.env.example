DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
NODE_ENV=development
PORT=4000
JWT_SECRET=your_jwt_secret_key
CLIENT_URL=http://localhost:3000
# You can also provide multiple frontend URLs in CLIENT_URL (comma-separated):
# CLIENT_URL=http://localhost:3000,https://teamfore.com,https://teamfore-web.vercel.app
# Optional: public API base URL used for generated docs / references
# PUBLIC_API_URL=https://backend-production-0738.up.railway.app
# Optional: comma-separated allowlist for multiple frontends
# CLIENT_URLS=https://teamfore.vercel.app,https://your-custom-domain.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Optional. Prefer relative path so one config works in both local + production.
# GOOGLE_CALLBACK_URL=/auth/google/callback
# If you use an absolute URL instead, add every exact callback URL in Google Cloud:
# - http://localhost:4000/auth/google/callback
# - https://backend-production-4678.up.railway.app/auth/google/callback
# OAuth 2.0 -> Authorised redirect URIs
GOOGLE_CALLBACK_URL=/auth/google/callback
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=TeamFore
TEAM_MIN_CAPACITY_WARNING_PERCENT=50
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_REDIRECT_URI=https://your-api-url/slack/oauth/callback
ENCRYPTION_KEY=your_32_byte_hex_encryption_key
GOOGLE_CALENDAR_ENABLED=