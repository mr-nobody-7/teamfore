datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum Role {
  USER
  MANAGER
  ADMIN
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum Session {
  FULL_DAY
  FIRST_HALF
  SECOND_HALF
}

enum AvailabilityStatus {
  AVAILABLE
  ON_LEAVE
  WORKING_REMOTELY
  HALF_DAY
  BUSY
  FOCUS_TIME
}

enum WorkloadLevel {
  LIGHT
  NORMAL
  HEAVY
}

enum HolidayCategory {
  COMPANY
  NATIONAL
  REGIONAL
}

enum AuditAction {
  // Authentication
  USER_REGISTERED
  USER_LOGIN
  USER_LOGIN_FAILED

  // User management
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED

  // Team management
  TEAM_CREATED
  TEAM_UPDATED
  TEAM_DELETED

  // Settings
  LEAVE_TYPES_UPDATED

  // Availability
  USER_AVAILABILITY_UPDATED

  // Leave management
  LEAVE_APPLIED
  LEAVE_APPROVED
  LEAVE_REJECTED
  LEAVE_CANCELLED
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users                User[]
  teams                Team[]
  leaveTypeSettings    WorkspaceLeaveType[]
  availabilityStatuses UserAvailabilityStatus[]
  workloadStatuses     UserWorkloadStatus[]
  publicHolidays       PublicHoliday[]
  feedbackEntries      FeedbackEntry[]
}

model Team {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  users User[]
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  team                   Team?          @relation(fields: [teamId], references: [id])
  teamId                 String?
  requestedLeaveRequests LeaveRequest[]
  availabilityStatuses   UserAvailabilityStatus[]
  workloadStatuses       UserWorkloadStatus[]
  feedbackEntries        FeedbackEntry[]

  approvedLeaveRequests LeaveRequest[] @relation("Approver")
}

model LeaveRequest {
  id           String      @id @default(uuid())
  user         User        @relation(fields: [userId], references: [id])
  userId       String
  teamId       String
  startDate    DateTime
  startSession Session     @default(FULL_DAY)
  endDate      DateTime
  endSession   Session     @default(FULL_DAY)
  type         String
  status       LeaveStatus @default(PENDING)
  reason       String?
  approver     User?       @relation("Approver", fields: [approverId], references: [id])
  approverId   String?
  comment      String?
  created_at   DateTime    @default(now())

  @@index([teamId])
  @@index([startDate])
  @@index([endDate])
  @@index([status])
}

// Append-only audit trail. Intentionally no FK to User so logs survive
// user deletion and failed-auth attempts can be recorded without a userId.
model AuditLog {
  id          String      @id @default(uuid())
  action      AuditAction
  userId      String?     // actor — null for failed/unauthenticated actions
  workspaceId String?     // workspace context
  targetId    String?     // affected entity ID (userId, leaveRequestId, …)
  targetType  String?     // "User" | "LeaveRequest"
  ipAddress   String?
  metadata    Json?       // flexible extra context (email, leaveType, etc.)
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([workspaceId])
  @@index([action])
  @@index([createdAt])
}

model WorkspaceLeaveType {
  id          String    @id @default(uuid())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  type        String    // internal key: built-in enum name or UUID for custom
  label       String    // human-readable display name
  isActive    Boolean   @default(true)
  isCustom    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, type])
  @@index([workspaceId])
}

model UserAvailabilityStatus {
  id          String             @id @default(uuid())
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  date        DateTime
  status      AvailabilityStatus @default(AVAILABLE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([userId, date])
  @@index([workspaceId, date])
  @@index([userId, date])
}

model UserWorkloadStatus {
  id          String        @id @default(uuid())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  date        DateTime
  workload    WorkloadLevel @default(NORMAL)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([userId, date])
  @@index([workspaceId, date])
  @@index([userId, date])
}

model PublicHoliday {
  id          String          @id @default(uuid())
  workspace   Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String?
  name        String
  date        DateTime
  category    HolidayCategory
  region      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([date])
  @@index([workspaceId, date])
  @@index([category, region, date])
}

model FeedbackEntry {
  id          String   @id @default(uuid())
  message     String
  userId      String
  workspaceId String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
}
