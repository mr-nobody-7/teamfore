# Server-side backend base URL used by Next.js rewrites.
# Set this to your Railway backend URL in production.
# Local value: http://localhost:4000
API_URL=http://localhost:4000

# Optional fallback if API_URL is not set.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
