# Server-side backend base URL used by Next.js rewrites.
# Set this to your Railway backend URL in production.
# Local value: http://localhost:4000
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Do not set NEXT_PUBLIC_API_URL in the web app.
# Browser requests should go through /api and be rewritten server-side.
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

NEXT_PUBLIC_VAPID_PUBLIC_KEY=vapid_public_key_here
